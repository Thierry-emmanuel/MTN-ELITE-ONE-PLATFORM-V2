# Serveur
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Auth
JWT_SECRET=<your-strong-secret-min-32-chars>
JWT_EXPIRES_IN=7d

# Base de données PostgreSQL (NeonDB - Pooler)
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require
DB_HOST=<neon-pooler-host>
DB_PORT=5432
DB_USERNAME=<neondb_owner>
DB_PASSWORD=<password>
DB_NAME=neondb
DB_SYNCHRONIZE=true
DB_SSL=true

# Base de données MongoDB (Mongoose pour Articles et Hero Banners)
MONGODB_URI=mongodb://localhost:27017/eliteone

# Cache Redis (BullMQ / Websockets / Throttler)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=300

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
