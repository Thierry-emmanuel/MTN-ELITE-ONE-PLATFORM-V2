# Serveur
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Base de données PostgreSQL (TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_NAME=eliteone
DB_SYNCHRONIZE=true

# Base de données MongoDB (Mongoose pour Articles et Hero Banners)
MONGODB_URI=mongodb://localhost:27017/eliteone

# Cache Redis (BullMQ / Websockets / Throttler)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=300
